---
import { Github, Linkedin, Twitter, Mail, Heart } from 'lucide-react';
---

<footer class="bg-gray-900 text-gray-300">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid md:grid-cols-4 gap-8 mb-8">
      <div class="md:col-span-2">
        <div class="mb-4 flex items-center gap-3">
          <img src="/spinedev-icon-yellow.png" alt="SpineDev Icon" class="h-2 w-auto" />
          <img src="/spinedev-text-yellow.png" alt="SpineDev" class="h-24 w-auto" />
        </div>
        <p class="text-gray-400 mb-4 max-w-md">
          Transformamos ideas en experiencias digitales excepcionales. Desarrollo web profesional con pasión y dedicación.
        </p>
        <div class="flex gap-4">
          <a href="#" class="p-2 bg-gray-800 rounded-lg hover:bg-primary-600 transition-colors" aria-label="GitHub">
            <Github className="w-5 h-5" />
          </a>
          <a href="#" class="p-2 bg-gray-800 rounded-lg hover:bg-primary-600 transition-colors" aria-label="LinkedIn">
            <Linkedin className="w-5 h-5" />
          </a>
          <a href="#" class="p-2 bg-gray-800 rounded-lg hover:bg-primary-600 transition-colors" aria-label="Twitter">
            <Twitter className="w-5 h-5" />
          </a>
          <a href="mailto:contacto@integria.com" class="p-2 bg-gray-800 rounded-lg hover:bg-primary-600 transition-colors" aria-label="Email">
            <Mail className="w-5 h-5" />
          </a>
        </div>
      </div>

      <div>
        <h4 class="text-white font-semibold mb-4">Enlaces Rápidos</h4>
        <ul class="space-y-2">
          <li><a href="#inicio" class="hover:text-primary-400 transition-colors">Inicio</a></li>
          <li><a href="#servicios" class="hover:text-primary-400 transition-colors">Servicios</a></li>
          <li><a href="#nosotros" class="hover:text-primary-400 transition-colors">Nosotros</a></li>
          <li><a href="#portafolio" class="hover:text-primary-400 transition-colors">Portafolio</a></li>
          <li><a href="#contacto" class="hover:text-primary-400 transition-colors">Contacto</a></li>
        </ul>
      </div>

      <div>
        <h4 class="text-white font-semibold mb-4">Servicios</h4>
        <ul class="space-y-2">
          <li><a href="#servicios" class="hover:text-primary-400 transition-colors">Desarrollo Web</a></li>
          <li><a href="#servicios" class="hover:text-primary-400 transition-colors">Apps Móviles</a></li>
          <li><a href="#servicios" class="hover:text-primary-400 transition-colors">E-Commerce</a></li>
          <li><a href="#servicios" class="hover:text-primary-400 transition-colors">UI/UX Design</a></li>
          <li><a href="#servicios" class="hover:text-primary-400 transition-colors">Consultoría</a></li>
        </ul>
      </div>
    </div>

    <div class="border-t border-gray-800 pt-8 flex flex-col sm:flex-row justify-between items-center gap-4">
      <p class="text-sm text-gray-400">
        © {new Date().getFullYear()} SpineDev. Todos los derechos reservados.
      </p>
      <p class="text-sm text-gray-400 flex items-center gap-2">
        Hecho por SpineDev
      </p>
    </div>
  </div>
</footer>
