---
import { Mail, Copy } from 'lucide-react';
---

<footer class="bg-gray-900 text-gray-300">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <!-- Layout responsive: centrado en móvil, justify-between en desktop -->
    <div class="flex flex-col md:flex-row md:justify-between md:items-start gap-8 mb-8">
      <!-- Logo y descripción -->
      <div class="text-center md:text-left max-w-md">
        <div class="mb-4 flex justify-center md:justify-start">
          <img src="/Spinedev logo horizontal blanco.png" alt="SpineDev" class="h-12 w-auto" />
        </div>
        <p class="text-gray-300 footer-description" data-i18n="footer.description">
          Transformamos ideas en experiencias digitales. Desarrollo web profesional con pasión y dedicación.
        </p>
      </div>

      <!-- Email de contacto -->
      <div class="text-center md:text-right">
        <h4 class="text-white font-semibold mb-4">Contacto</h4>
        <div class="flex items-center justify-center md:justify-end gap-2 bg-gray-800 rounded-lg px-4 py-3 max-w-sm mx-auto md:mx-0">
          <Mail className="w-5 h-5 text-secondary-400 flex-shrink-0" />
          <span class="text-gray-300 text-sm font-mono">contact@spinedev.pro</span>
          <button 
            id="copy-email-btn"
            class="p-2 hover:bg-gray-700 rounded-lg transition-colors group"
            aria-label="Copiar email"
            title="Copiar email"
          >
            <Copy className="w-4 h-4 text-gray-400 group-hover:text-secondary-400 transition-colors" />
          </button>
        </div>
        <p id="copy-feedback" class="text-xs text-secondary-400 mt-2 opacity-0 transition-opacity">
          ✓ Email copiado
        </p>
      </div>
    </div>

    <!-- Copyright centrado -->
    <div class="border-t border-gray-800 pt-6 text-center">
      <p class="text-sm text-gray-300 footer-rights">
        © {new Date().getFullYear()} SpineDev. <span data-i18n="footer.rights">Todos los derechos reservados</span>.
      </p>
    </div>
  </div>
</footer>

<script>
  import { translations } from '../i18n/translations';
  
  if (typeof window !== 'undefined') {
    function updateFooterText() {
      const language = (localStorage.getItem('language') as 'es' | 'en') || 'es';
      const t = translations[language];
      
      document.querySelectorAll('[data-i18n]').forEach((element) => {
        const key = element.getAttribute('data-i18n');
        if (key) {
          const keys = key.split('.');
          let value: any = t;
          for (const k of keys) {
            value = value[k];
          }
          if (typeof value === 'string') {
            element.textContent = value;
          }
        }
      });
    }

    updateFooterText();
    
    window.addEventListener('languageChange', updateFooterText);

    // Copiar email al clipboard
    const copyBtn = document.getElementById('copy-email-btn');
    const feedback = document.getElementById('copy-feedback');
    
    if (copyBtn && feedback) {
      copyBtn.addEventListener('click', async () => {
        try {
          await navigator.clipboard.writeText('contact@spinedev.pro');
          feedback.style.opacity = '1';
          setTimeout(() => {
            feedback.style.opacity = '0';
          }, 2000);
        } catch (err) {
          console.error('Error al copiar:', err);
        }
      });
    }
  }
</script>
