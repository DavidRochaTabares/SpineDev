---
import ThemeToggle from './ThemeToggle';
import LanguageSelector from './LanguageSelector';
---

<nav class="fixed top-0 left-0 right-0 z-50 bg-white/80 dark:bg-gray-950/80 backdrop-blur-md border-b border-gray-200 dark:border-gray-800">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <div class="flex items-center">
        <a href="#" class="flex items-center gap-3">
          <img src="/spinedev-icon-yellow.png" alt="SpineDev Icon" class="h-12 w-auto dark:hidden" />
          <img src="/spinedev-icon-navy.png" alt="SpineDev Icon" class="h-12 w-auto hidden dark:block" />
          <img src="/spinedev-text-yellow.png" alt="SpineDev" class="h-12 w-auto dark:hidden" />
          <img src="/spinedev-text-navy.png" alt="SpineDev" class="h-12 w-auto hidden dark:block" />
        </a>
      </div>
      
      <div class="hidden md:flex items-center space-x-8">
        <a href="#inicio" class="text-gray-700 dark:text-gray-300 hover:text-primary-600 dark:hover:text-primary-400 transition-colors">
          Inicio
        </a>
        <a href="#servicios" class="text-gray-700 dark:text-gray-300 hover:text-primary-600 dark:hover:text-primary-400 transition-colors">
          Servicios
        </a>
        <a href="#nosotros" class="text-gray-700 dark:text-gray-300 hover:text-primary-600 dark:hover:text-primary-400 transition-colors">
          Nosotros
        </a>
        <a href="#portafolio" class="text-gray-700 dark:text-gray-300 hover:text-primary-600 dark:hover:text-primary-400 transition-colors">
          Portafolio
        </a>
        <a href="#contacto" class="text-gray-700 dark:text-gray-300 hover:text-primary-600 dark:hover:text-primary-400 transition-colors">
          Contacto
        </a>
      </div>

      <div class="flex items-center space-x-4">
        <LanguageSelector client:load />
        <ThemeToggle client:load />
        <a 
          href="#contacto" 
          class="hidden sm:inline-flex px-6 py-2 bg-gradient-to-r from-primary-600 to-secondary-600 text-white rounded-lg hover:shadow-lg hover:scale-105 transition-all duration-200 font-medium"
        >
          Hablemos
        </a>
      </div>
    </div>
  </div>
</nav>

<script>
  if (typeof window !== 'undefined') {
    const theme = localStorage.getItem('theme');
    if (theme === 'dark' || (!theme && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
      document.documentElement.classList.add('dark');
    }
  }
</script>
